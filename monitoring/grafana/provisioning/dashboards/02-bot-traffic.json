{
  "uid": "bot-traffic",
  "title": "GuardUs · Bot Traffic",
  "tags": ["guardus", "bot", "traffic"],
  "timezone": "browser",
  "schemaVersion": 39,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "panels": [
    {
      "id": 1, "title": "OpenResty 요청 rate (status)", "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        { "expr": "sum by (status) (count_over_time({container=\"botgate-openresty-1\"} | json | __error__=\"\" [1m])) / 60", "refId": "A", "legendFormat": "{{status}}" }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },
    {
      "id": 2, "title": "OpenResty 5xx", "type": "timeseries",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        { "expr": "sum (count_over_time({container=\"botgate-openresty-1\"} | json | status >= 500 [1m]))", "refId": "A", "legendFormat": "5xx" },
        { "expr": "sum (count_over_time({container=\"botgate-openresty-1\"} | json | status >= 400 | status < 500 [1m]))", "refId": "B", "legendFormat": "4xx" }
      ]
    },
    {
      "id": 3, "title": "Top hosts (도메인별 트래픽)", "type": "barchart",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        { "expr": "topk(10, sum by (host) (count_over_time({container=\"botgate-openresty-1\"} | json | __error__=\"\" [$__range])))", "refId": "A", "instant": true }
      ]
    },
    {
      "id": 4, "title": "Top User-Agents", "type": "logs",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        { "expr": "{container=\"botgate-openresty-1\"} | json | x_bot_verified != \"\"", "refId": "A" }
      ],
      "options": { "showTime": true, "wrapLogMessage": false, "sortOrder": "Descending" }
    },
    {
      "id": 5, "title": "Errors / Warnings (Spring Boot)", "type": "logs",
      "gridPos": { "x": 0, "y": 16, "w": 24, "h": 10 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        { "expr": "{container=~\"guardus-new-(admin|internal)-api-1\"} |~ \"(?i)error|warn|exception\"", "refId": "A" }
      ],
      "options": { "showTime": true, "wrapLogMessage": true, "sortOrder": "Descending" }
    }
  ]
}
