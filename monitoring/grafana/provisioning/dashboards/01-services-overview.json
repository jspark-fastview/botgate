{
  "uid": "services-overview",
  "title": "GuardUs · Services Overview",
  "tags": ["guardus", "services"],
  "timezone": "browser",
  "schemaVersion": 39,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1, "title": "Request rate (RPS)", "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "sum by (service) (rate(http_server_requests_seconds_count[1m]))", "legendFormat": "{{service}}", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },
    {
      "id": 2, "title": "P95 latency (ms)", "type": "timeseries",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "histogram_quantile(0.95, sum by (le, service) (rate(http_server_requests_seconds_bucket[5m]))) * 1000", "legendFormat": "p95 {{service}}", "refId": "A" },
        { "expr": "histogram_quantile(0.99, sum by (le, service) (rate(http_server_requests_seconds_bucket[5m]))) * 1000", "legendFormat": "p99 {{service}}", "refId": "B" }
      ],
      "fieldConfig": { "defaults": { "unit": "ms" } }
    },
    {
      "id": 3, "title": "5xx rate", "type": "timeseries",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "sum by (service, status) (rate(http_server_requests_seconds_count{status=~\"5..\"}[1m]))", "legendFormat": "{{service}} {{status}}", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },
    {
      "id": 4, "title": "Top endpoints by latency (sum)", "type": "table",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "topk(10, sum by (uri, service) (rate(http_server_requests_seconds_sum[5m])))", "format": "table", "instant": true, "refId": "A" }
      ]
    },
    {
      "id": 5, "title": "JVM heap used", "type": "timeseries",
      "gridPos": { "x": 0, "y": 16, "w": 12, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "sum by (service) (jvm_memory_used_bytes{area=\"heap\"})", "legendFormat": "{{service}}", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes" } }
    },
    {
      "id": 6, "title": "HikariCP connections (active / max)", "type": "timeseries",
      "gridPos": { "x": 12, "y": 16, "w": 12, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "hikaricp_connections_active", "legendFormat": "active {{service}}", "refId": "A" },
        { "expr": "hikaricp_connections_pending", "legendFormat": "pending {{service}}", "refId": "B" },
        { "expr": "hikaricp_connections_max", "legendFormat": "max {{service}}", "refId": "C" }
      ]
    },
    {
      "id": 7, "title": "Caffeine cache hit rate (admin-api stats)", "type": "stat",
      "gridPos": { "x": 0, "y": 23, "w": 8, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "sum(rate(cache_gets_total{result=\"hit\"}[5m])) / clamp_min(sum(rate(cache_gets_total[5m])), 1)", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "red", "value": 0 },
            { "color": "orange", "value": 0.5 },
            { "color": "green", "value": 0.8 }
          ]}
        }
      }
    },
    {
      "id": 8, "title": "Cache hits vs misses (per second)", "type": "timeseries",
      "gridPos": { "x": 8, "y": 23, "w": 16, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "sum by (result) (rate(cache_gets_total[1m]))", "legendFormat": "{{result}}", "refId": "A" }
      ]
    }
  ]
}
